# Copie para .env e preencha (nao commite .env)
# Configuracoes de IA, publicacao e pipeline autonomo

OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Gera imagem via DALL-E so quando nao ha screenshot do site
# MARKETINGAI_USE_DALLE=true

# Origem da arte: marketing_dalle, screenshot ou both
# MARKETINGAI_IMAGE_SOURCE=marketing_dalle

# Crawl
# MARKETINGAI_MAX_CRAWL_PAGES=5
# MARKETINGAI_MAX_CRAWL_DEPTH=2

# Logging e output
# MARKETINGAI_LOG_LEVEL=INFO
# MARKETINGAI_OUTPUT_DIR=../ia_pipeline/output
# MARKETINGAI_TENANT_ID=default

# AI image
# MARKETINGAI_IMAGE_PROVIDER=auto
# MARKETINGAI_IMAGE_STYLE=modern
# MARKETINGAI_IMAGE_VARIATIONS=2
# STABLE_DIFFUSION_API_URL=
# STABLE_DIFFUSION_API_KEY=

# Social publishing
# MARKETINGAI_PUBLISHER_MODE=mock
# MARKETINGAI_QUEUE_RETRY_LIMIT=3
# MARKETINGAI_QUEUE_RETRY_DELAY_SECONDS=5
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_ACCOUNT_ID=
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_ORGANIZATION_ID=
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_TOKEN_SECRET=

# Multi-agent
# MARKETINGAI_AGENT_MAX_CYCLES=2
# MARKETINGAI_AGENT_DEBUG=false
# MARKETINGAI_AUTO_PUBLISH_DEFAULT=false
