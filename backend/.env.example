# Copie para .env e preencha (nao commite .env)

MARKETINGAI_ENV=development
SECRET_KEY=troque-esta-chave-em-producao
DATABASE_URL=sqlite:///./marketingai.db
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
RUN_MIGRATIONS=0
ACCESS_TOKEN_EXPIRE_MINUTES=1440

OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Crawl
# MARKETINGAI_MAX_CRAWL_PAGES=5
# MARKETINGAI_MAX_CRAWL_DEPTH=2

# Logging e output
